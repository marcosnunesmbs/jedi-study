generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// AUTH
// ─────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  displayName  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  subjects   Subject[]
  studyPaths StudyPath[]
}

// ─────────────────────────────────────────────
// CORE LEARNING STRUCTURE
// ─────────────────────────────────────────────

model Subject {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  title       String
  description String?
  skillLevel  String   @default("BEGINNER") // SkillLevel: BEGINNER | INTERMEDIATE | ADVANCED
  goals       String   @db.Text      // JSON-encoded string[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  studyPaths StudyPath[]

  @@index([userId])
}

model StudyPath {
  id        String @id @default(cuid())
  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation(fields: [userId], references: [id])

  version        Int     @default(1)
  isActive       Boolean @default(true)
  status         String  @default("GENERATING") // PathStatus: GENERATING | ACTIVE | ARCHIVED
  rawAgentOutput String? @db.Text // JSON string — full PathGenerator output

  estimatedHours Int @default(0)
  totalPhases    Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  phases Phase[]

  @@index([subjectId, isActive])
  @@index([userId])
}

model Phase {
  id          String    @id @default(cuid())
  studyPathId String
  studyPath   StudyPath @relation(fields: [studyPathId], references: [id], onDelete: Cascade)

  order          Int
  title          String
  description    String  @db.Text
  objectives     String @db.Text // JSON-encoded string[]
  topics         String @db.Text // JSON-encoded string[]
  status         String  @default("LOCKED") // PhaseStatus: LOCKED | ACTIVE | COMPLETED
  estimatedHours Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks    Task[]
  contents Content[]

  @@unique([studyPathId, order])
  @@index([studyPathId])
}

model Task {
  id      String @id @default(cuid())
  phaseId String
  phase   Phase  @relation(fields: [phaseId], references: [id], onDelete: Cascade)

  order          Int
  title          String
  description    String  @db.Text
  type           String  @default("EXERCISE") // TaskType: READING | EXERCISE | PROJECT | QUIZ
  status         String  @default("PENDING")  // TaskStatus: PENDING | IN_PROGRESS | SUBMITTED | PASSED | FAILED
  projectContext String? @db.Text // JSON-encoded ProjectContext (only for PROJECT type)
  maxScore       Int     @default(100)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  submissions Submission[]

  @@unique([phaseId, order])
  @@index([phaseId])
}

model Submission {
  id     String @id @default(cuid())
  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  attempt     Int
  content     String  @db.Text
  contentType String  @default("TEXT") // ContentType: TEXT | CODE | MARKDOWN
  status      String  @default("PENDING") // SubmissionStatus: PENDING | ANALYZING | COMPLETE | ERROR
  score       Int?
  passed      Boolean?

  createdAt DateTime @default(now())

  analysis Analysis?

  @@index([taskId])
}

model Analysis {
  id           String     @id @default(cuid())
  submissionId String     @unique
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  agentType    String // AgentType: TASK_ANALYZER | PROJECT_ANALYZER
  feedback     String @db.Text
  strengths    String @db.Text // JSON-encoded string[]
  improvements String @db.Text // JSON-encoded string[]
  score        Int
  passed       Boolean
  rawOutput    String @db.Text // JSON string

  createdAt DateTime @default(now())
}

model Content {
  id      String @id @default(cuid())
  phaseId String
  phase   Phase  @relation(fields: [phaseId], references: [id], onDelete: Cascade)

  topic  String?
  type   String @default("EXPLANATION") // ContentBlock: EXPLANATION | EXAMPLE | SUMMARY | RESOURCE_LIST
  title  String
  body   String @db.Text
  status String @default("PENDING") // ContentStatus: PENDING | STREAMING | COMPLETE | ERROR
  jobId  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([phaseId])
}

// ─────────────────────────────────────────────
// JOB TRACKING
// ─────────────────────────────────────────────

model AgentJob {
  id          String   @id @default(cuid())
  bullJobId   String?  @unique
  type        String   // AgentType
  status      String   @default("QUEUED") // JobStatus: QUEUED | PROCESSING | COMPLETE | FAILED
  referenceId String
  error       String?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())

  @@index([referenceId])
  @@index([status])
}

// ─────────────────────────────────────────────
// TOKEN AUDIT
// ─────────────────────────────────────────────

model TokenUsage {
  id            String   @id @default(cuid())
  agentType     String   // AgentType
  referenceId   String
  referenceType String   // "StudyPath" | "Submission" | "Content"
  model         String
  inputTokens   Int
  outputTokens  Int
  totalTokens   Int
  estimatedCostUsd Float @default(0)
  durationMs    Int?
  createdAt     DateTime @default(now())

  @@index([agentType])
  @@index([createdAt])
  @@index([referenceId])
}
