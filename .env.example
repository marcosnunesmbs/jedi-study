# MySQL
DATABASE_URL="mysql://jedi_user:jedi_pass@localhost:3307/jedi_study"
DB_ROOT_PASSWORD=root_pass
DB_NAME=jedi_study
DB_USER=jedi_user
DB_PASSWORD=jedi_pass

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=generate_with_openssl_rand_hex_32
JWT_EXPIRES_IN=24h

# Google ADK / Gemini
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-1.5-pro

# Service URLs (for local development without Docker)
AGENTS_BASE_URL=http://localhost:8000
VITE_API_URL=http://localhost:3000

# Gemini Costs (USD per 1M tokens)
# Default for 1.5 Pro: $3.50 input, $10.50 output
GEMINI_COST_INPUT_1M=3.50
GEMINI_COST_OUTPUT_1M=10.50

# API
API_PORT=3000
NODE_ENV=development
